{
  "manifest_version": 3,
  "name": "PCAP Merger & SIP Analyzer",
  "version": "1.0.0",
  "description": "Merge PCAPs, extract SDP media IPs, and filter RTP/signaling streams",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
